# Gemini API — powers chat, auto chat titles, and image generation
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (optional — leave blank to run in local-only/no-login mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Apps Script Web App URL — for sending emails (contact forms, notifications)
GOOGLE_SCRIPT_EMAIL_URL=
